{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"c7a3b581ba3d248d2b52cc3c37990d1d233d0a97ee392ee03fbae87c3687d829","created_at":"2026-03-10T19:41:22Z","created_by":"mayor","crystallizes":0,"defer_until":null,"description":"The gt daemon (PID 60083) continuously spawns bd commands (bd list, bd show \u003crig-bead\u003e, bd version) for all rigs including docked ones. This results in dozens of short-lived bd processes per second, each opening a Dolt connection. Observed ~30% sustained CPU on Dolt (PID 340765) with all rigs docked and all refineries/witnesses stopped. The daemon should skip docked rigs entirely in its patrol loop.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"gt-8l1","is_template":0,"issue_type":"bug","last_activity":null,"metadata":"{}","mol_type":"","notes":"","original_size":null,"owner":"eric.wassail@gmail.com","payload":"","pinned":0,"priority":1,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"Daemon polls docked rigs in tight loop, causing sustained Dolt CPU","updated_at":"2026-03-10T19:41:22Z","waiters":"","wisp_type":"","work_type":""}
